@model MovieTicketDB.Models.Movy
@{ ViewBag.Title = Model.Title; }
<section class="page-shell movie-detail-page">
    <div class="container detail-grid">
        <div class="poster"><img src="@Url.Content("~/Content/images/" + Model.Poster)" alt="@Model.Title" /><span class="poster-badge">@Model.Status</span></div>
        <div class="detail-content">
            <div class="eyebrow">@Model.Country · @Model.Format</div><h1>@Model.Title</h1>
            <div class="tag-list"><span class="tag">@Model.AgeLimit</span><span class="tag">@Model.Duration phút</span><span class="tag">@Model.Rating/10</span><span class="tag">@Model.Genre</span>@if(Model.IsEarlyAccess){<span class="tag tag-accent">Có suất chiếu sớm</span>}</div>
            <p class="detail-copy">@Model.Description</p>
            <div class="facts"><div class="fact"><span>Đạo diễn</span><strong>@Model.Director</strong></div><div class="fact"><span>Khởi chiếu</span><strong>@Model.ReleaseDate.ToString("dd/MM/yyyy")</strong></div><div class="fact"><span>Ngôn ngữ</span><strong>@Model.Language</strong></div><div class="fact"><span>Định dạng</span><strong>@Model.Format</strong></div></div>
            <a class="btn btn-primary" href="@Url.Action("BuyTicket", new { id = Model.MovieID })">Chọn suất chiếu</a><a class="btn btn-outline" href="@Url.Action("Index")">Quay lại</a>
        </div>
    </div>
    <div class="container cast-section">
        <div class="section-head"><div><div class="eyebrow">Dàn diễn viên</div><h2>Diễn viên & vai diễn</h2></div><p>@Model.Actors</p></div>
        <div class="cast-grid">
            @foreach (var actor in Model.Cast) { <article class="cast-card"><img src="@Url.Content("~/Content/images/" + actor.Image)" alt="@actor.Name" /><div><h3>@actor.Name</h3><p>@actor.Character</p></div></article> }
        </div>
    </div>
</section>
