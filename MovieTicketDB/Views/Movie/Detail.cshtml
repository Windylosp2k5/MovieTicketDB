@model MovieTicketDB.Models.Movy

@{
    ViewBag.Title = "Chi tiết phim";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .detail-box {
        background: #fffdf0;
        padding: 25px;
    }

    .detail-title {
        font-size: 30px;
        border-bottom: 2px solid #333;
        padding-bottom: 10px;
        margin-bottom: 25px;
    }

    .movie-detail {
        display: flex;
        gap: 30px;
    }

    .poster-box img {
        width: 220px;
        height: 320px;
        object-fit: cover;
    }

    .buy-btn {
        display: inline-block;
        margin-top: 15px;
        background: red;
        color: white;
        padding: 10px 18px;
        border-radius: 5px;
        font-weight: bold;
        text-decoration: none;
    }

    .movie-content h2 {
        margin-top: 0;
        font-size: 28px;
        border-bottom: 1px solid #ccc;
        padding-bottom: 15px;
    }

    .info p {
        margin: 5px 0;
        font-size: 15px;
    }

    .rating-box {
        margin-top: 15px;
        display: flex;
        gap: 8px;
    }

    .tag {
        border: 2px solid #333;
        padding: 8px 12px;
        font-weight: bold;
        background: white;
    }

    .tag-age {
        background: #5c8a2b;
        color: white;
    }

    .tab-box {
        text-align: center;
        margin: 30px 0 20px 0;
    }

    .tab-btn {
        background: red;
        color: white;
        padding: 12px 35px;
        font-weight: bold;
        text-decoration: none;
    }

    .description {
        font-size: 16px;
        line-height: 1.7;
        text-align: justify;
    }
</style>

<div class="detail-box">

    <div class="detail-title">Nội Dung Phim</div>

    <div class="movie-detail">

        <div class="poster-box">
            <img src="@Url.Content("~/Content/Images/" + Model.Poster)" />

            <br />

            <a href="/Movie/BuyTicket/@Model.MovieID" class="buy-btn">
                🎟 MUA VÉ
            </a>
        </div>

        <div class="movie-content">

            <h2>@Model.Title</h2>

            <div class="info">
                <p><b>Đạo diễn:</b> @Model.Director</p>
                <p><b>Diễn viên:</b> @Model.Actors</p>
                <p><b>Thể loại:</b> @Model.Genre</p>
                <p><b>Khởi chiếu:</b> @Model.ReleaseDate</p>
                <p><b>Thời lượng:</b> @Model.Duration phút</p>
                <p><b>Ngôn ngữ:</b> @Model.Language</p>
                <p><b>Rated:</b> @Model.AgeLimit</p>
                <p><b>Đánh giá:</b> @Model.Rating</p>
            </div>

            <div class="rating-box">
                <span class="tag tag-age">P</span>
                <span class="tag">4DX</span>
                <span class="tag">STARIUM</span>
                <span class="tag">ULTRA 4DX</span>
            </div>

        </div>

    </div>

    <div class="tab-box">
        <span class="tab-btn">Chi tiết</span>
    </div>

    <div class="description">
        @Model.Description
    </div>

</div>