@model IEnumerable<MovieTicketDB.Models.Event>
@{
    ViewBag.Title = "Ưu đãi";
}
<section class="page-shell">
    <div class="container">
        <div class="section-head">
            <div><div class="eyebrow">Dành riêng cho bạn</div><h1 class="page-title">Ưu đãi PHP Cinema</h1></div>
            <p>Thêm nhiều niềm vui cho mỗi lần đến rạp với những chương trình dành cho thành viên.</p>
        </div>
        <div class="event-grid">
            @foreach (var item in Model)
            {
                <article class="event-card" style="@("--card-accent:" + item.Accent)">
                    <span class="event-label">@item.Label</span>
                    <div>
                        <h3>@item.Title</h3>
                        <p>@item.Description</p>
                        <a class="btn btn-primary" href="@Url.Action("EventDetail", new { id = item.EventID })">Xem chi tiết</a>
                    </div>
                </article>
            }
        </div>
    </div>
</section>
