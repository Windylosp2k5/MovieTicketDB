@model IEnumerable<MovieTicketDB.Models.ShowTime>
@{
    var movie = (MovieTicketDB.Models.Movy)ViewBag.Movie;
    ViewBag.Title = "Suất chiếu " + movie.Title;
}
<section class="page-shell">
    <div class="container">
        <div class="section-head">
            <div>
                <div class="eyebrow">Bước 1 / 3</div>
                <h1 class="page-title">Chọn suất chiếu</h1>
            </div>
            <p><strong>@movie.Title</strong><br />@movie.Genre · @movie.Duration phút</p>
        </div>

        <div class="date-tabs">
            @foreach (var date in Model.Select(x => x.ShowDate.Date).Distinct())
            {
                <div class="date-tab">
                    <strong>@date.ToString("dd/MM")</strong>
                    <span>@date.ToString("dddd")</span>
                </div>
            }
        </div>

        <div class="showtime-groups">
            @foreach (var cinemaGroup in Model.GroupBy(x => x.Room.Cinema))
            {
                <article class="showtime-group">
                    <h3>@cinemaGroup.Key.CinemaName</h3>
                    <p style="color:var(--muted)">@cinemaGroup.Key.Address</p>
                    <div class="time-list">
                        @foreach (var show in cinemaGroup)
                        {
                            <a class="time-chip" href="@Url.Action("SelectSeat", new { showTimeId = show.ShowTimeID })">
                                @show.StartTime.ToString(@"hh\:mm")
                                <small>@show.ShowDate.ToString("dd/MM") · @show.Room.RoomName · @show.Price.ToString("N0")đ</small>
                            </a>
                        }
                    </div>
                </article>
            }
        </div>
    </div>
</section>
