@model IEnumerable<MovieTicketDB.Models.Cinema>
@{
    ViewBag.Title = "Hệ thống rạp";
}
<section class="page-shell">
    <div class="container">
        <div class="section-head">
            <div><div class="eyebrow">Gần bạn hơn</div><h1 class="page-title">Hệ thống rạp PHP Cinema</h1></div>
            <p>Phòng chiếu hiện đại, ghế ngồi thoải mái và chất lượng âm thanh hình ảnh cao cấp.</p>
        </div>
        <div class="cinema-grid">
            @foreach (var item in Model)
            {
                <article class="cinema-card" style="@("--card-accent:" + item.Accent)">
                    <div>
                        <h3>@item.CinemaName</h3>
                        <p>@item.Address</p>
                        <p>@item.Description</p>
                        <a class="btn btn-primary" href="@Url.Action("TheaterSchedule", new { id = item.CinemaID })">Xem lịch chiếu</a>
                    </div>
                </article>
            }
        </div>
    </div>
</section>
