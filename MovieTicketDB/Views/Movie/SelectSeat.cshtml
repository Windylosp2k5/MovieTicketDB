@model MovieTicketDB.Models.SeatSelectionViewModel
@{
    ViewBag.Title = "Chọn ghế";
    var booked = new System.Collections.Generic.HashSet<string>(Model.BookedSeats);
}
<section class="page-shell">
    <div class="container">
        <div class="section-head">
            <div><div class="eyebrow">Bước 2 / 3</div><h1 class="page-title">Chọn ghế ngồi</h1></div>
            <p>@Model.ShowTime.Movy.Title · @Model.ShowTime.ShowDate.ToString("dd/MM/yyyy") · @Model.ShowTime.StartTime.ToString(@"hh\:mm")</p>
        </div>
        @if (TempData["Error"] != null) { <div class="alert alert-error">@TempData["Error"]</div> }

        <form method="post" action="@Url.Action("Payment")" id="seatForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="showTimeId" value="@Model.ShowTime.ShowTimeID" />
            <div class="seat-layout">
                <div class="panel">
                    <div class="screen"><span>MÀN HÌNH</span></div>
                    <div class="seat-grid">
                        @foreach (var seat in Model.Seats)
                        {
                            var unavailable = booked.Contains(seat.SeatName);
                            <label>
                                <input class="seat-check" type="checkbox" name="seatNames" value="@seat.SeatName"
                                       data-price="@(seat.Type == "VIP" ? 120000 : Model.ShowTime.Price)"
                                       @(unavailable ? "disabled" : "") />
                                <span class="seat @(seat.Type == "VIP" ? "vip" : "") @(unavailable ? "booked" : "")">@seat.SeatName</span>
                            </label>
                        }
                    </div>
                    <div class="legend">
                        <span><i></i> Ghế thường</span>
                        <span><i style="background:#3c2b28"></i> Ghế VIP</span>
                        <span><i style="background:var(--accent)"></i> Đang chọn</span>
                        <span><i style="opacity:.28"></i> Đã đặt</span>
                    </div>
                </div>
                <aside class="panel booking-summary">
                    <div class="eyebrow">Thông tin đặt vé</div>
                    <h2>@Model.ShowTime.Movy.Title</h2>
                    <div class="summary-row"><span>Rạp</span><strong>@Model.ShowTime.Room.Cinema.CinemaName</strong></div>
                    <div class="summary-row"><span>Phòng</span><strong>@Model.ShowTime.Room.RoomName</strong></div>
                    <div class="summary-row"><span>Suất chiếu</span><strong>@Model.ShowTime.StartTime.ToString(@"hh\:mm"), @Model.ShowTime.ShowDate.ToString("dd/MM")</strong></div>
                    <div class="summary-row"><span>Ghế</span><strong id="selectedSeats">Chưa chọn</strong></div>
                    <div class="summary-row"><span>Tổng tiền</span><strong class="total" id="totalMoney">0đ</strong></div>
                    <button class="btn btn-primary" style="width:100%;margin-top:22px" type="submit">Tiếp tục thanh toán</button>
                </aside>
            </div>
        </form>
    </div>
</section>
@section scripts {
<script>
(function () {
    var checks = document.querySelectorAll('.seat-check:not([disabled])');
    var seats = document.getElementById('selectedSeats');
    var total = document.getElementById('totalMoney');
    function update() {
        var selected = [], amount = 0;
        for (var i = 0; i < checks.length; i++) {
            if (checks[i].checked) {
                selected.push(checks[i].value);
                amount += parseInt(checks[i].getAttribute('data-price'), 10);
            }
        }
        seats.textContent = selected.length ? selected.join(', ') : 'Chưa chọn';
        total.textContent = amount.toLocaleString('vi-VN') + 'đ';
    }
    for (var i = 0; i < checks.length; i++) checks[i].addEventListener('change', update);
})();
</script>
}
