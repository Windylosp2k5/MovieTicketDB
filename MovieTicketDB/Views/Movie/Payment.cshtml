
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>

    .payment-wrapper {
        background: white;
        padding: 40px;
        border-radius: 18px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        margin-top: 30px;
    }

    .payment-title {
        text-align: center;
        font-size: 38px;
        font-weight: bold;
        margin-bottom: 35px;
    }

    .payment-info {
        background: #fff4f4;
        padding: 25px;
        border-radius: 14px;
        font-size: 20px;
        line-height: 2;
    }

        .payment-info span {
            color: red;
            font-weight: bold;
        }

    .payment-methods {
        display: flex;
        justify-content: center;
        gap: 18px;
        flex-wrap: wrap;
        margin-top: 25px;
    }

    .payment-card input {
        display: none;
    }

    .payment-card span {
        width: 160px;
        height: 90px;
        background: white;
        border: 2px solid #eee;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        font-weight: bold;
        cursor: pointer;
        box-shadow: 0 3px 12px rgba(0,0,0,0.1);
        transition: 0.3s;
    }

        .payment-card span:hover {
            border-color: red;
            color: red;
            transform: translateY(-4px);
        }

    .payment-card input:checked + span {
        border-color: red;
        background: #fff0f0;
        color: red;
        transform: translateY(-4px);
    }

    .pay-button {
        text-align: center;
        margin-top: 35px;
    }

    .pay-btn {
        border: none;
        padding: 16px 45px;
        border-radius: 14px;
        background: linear-gradient(135deg,#ff9966,#ff5e62);
        color: white;
        font-size: 20px;
        font-weight: bold;
        transition: 0.3s;
    }

        .pay-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(255,94,98,0.35);
        }
</style>

<div class="payment-wrapper">

    <div class="payment-title">

        THANH TOÁN VÉ PHIM

    </div>

    <div class="payment-info">

        <p>
            🎟 Ghế đã chọn:
            <span>@ViewBag.SeatNames</span>
        </p>

        <p>
            👥 Tổng số ghế:
            <span>@ViewBag.TotalSeats</span>
        </p>

        <p>
            💰 Tổng tiền:
            <span>
                @String.Format("{0:N0}", ViewBag.TotalMoney) VNĐ
            </span>
        </p>

    </div>

    <h3 style="margin-top:30px; text-align:center;">

        Chọn phương thức thanh toán

    </h3>

    <form method="post"
          action="/Movie/ConfirmPayment">

        <div class="payment-methods">

            <label class="payment-card">

                <input type="radio"
                       name="paymentMethod"
                       value="PayPal" />

                <span>PayPal</span>

            </label>

            <label class="payment-card">

                <input type="radio"
                       name="paymentMethod"
                       value="Apple Pay" />

                <span>Apple Pay</span>

            </label>

            <label class="payment-card">

                <input type="radio"
                       name="paymentMethod"
                       value="MoMo" />

                <span>MoMo</span>

            </label>

            <label class="payment-card">

                <input type="radio"
                       name="paymentMethod"
                       value="Zalo Pay" />

                <span>Zalo Pay</span>

            </label>

            <label class="payment-card">

                <input type="radio"
                       name="paymentMethod"
                       value="Ngân Hàng" />

                <span>Ngân Hàng</span>

            </label>

        </div>

        <div class="pay-button">

            <button type="submit"
                    class="pay-btn">

                THANH TOÁN

            </button>

        </div>

    </form>

</div>

