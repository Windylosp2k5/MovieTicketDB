@model IEnumerable<MovieTicketDB.Models.TicketReceiptViewModel>
@{
    ViewBag.Title = "Vé của tôi";
}
<section class="page-shell">
    <div class="container">
        <div class="section-head">
            <div><div class="eyebrow">PHP Cinema Wallet</div><h1 class="page-title">Vé của tôi</h1></div>
            <a class="btn btn-primary" href="@Url.Action("Index")">Đặt vé mới</a>
        </div>
        @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
        @if (TempData["EmailStatus"] != null)
        {
            <div class="alert @((TempData["EmailSent"] as bool?) == true ? "alert-success" : "alert-warning")">@TempData["EmailStatus"]</div>
        }
        <div class="ticket-list">
            @foreach (var item in Model)
            {
                <article class="ticket">
                    <div class="ticket-main">
                        <div class="eyebrow">@item.Booking.Status</div>
                        <h2>@item.ShowTime.Movy.Title</h2>
                        <div class="facts">
                            <div class="fact"><span>Rạp</span><strong>@item.ShowTime.Room.Cinema.CinemaName</strong></div>
                            <div class="fact"><span>Phòng / Ghế</span><strong>@item.ShowTime.Room.RoomName · @string.Join(", ", item.Booking.SeatNames)</strong></div>
                            <div class="fact"><span>Thời gian</span><strong>@item.ShowTime.StartTime.ToString(@"hh\:mm") · @item.ShowTime.ShowDate.ToString("dd/MM/yyyy")</strong></div>
                            <div class="fact"><span>Thanh toán</span><strong>@item.Booking.PaymentMethod · @item.Booking.TotalMoney.ToString("N0")đ</strong></div>
                            @if (item.Booking.Concessions != null && item.Booking.Concessions.Any())
                            {
                                <div class="fact ticket-food"><span>Bắp &amp; nước</span><strong>@string.Join("; ", item.Booking.Concessions.Select(x => x.ProductName + " × " + x.Quantity))</strong></div>
                                <div class="fact"><span>Tiền món</span><strong>@item.Booking.ConcessionMoney.ToString("N0")đ</strong></div>
                            }
                        </div>
                    </div>
                    <div class="ticket-side">
                        <div>
                            <div class="ticket-code">@item.Booking.Code</div>
                            <div class="barcode"></div>
                            <small>Xuất trình mã này tại quầy soát vé</small>
                        </div>
                    </div>
                </article>
            }
            @if (!Model.Any())
            {
                <div class="panel empty-state">
                    <h2>Bạn chưa có vé nào</h2>
                    <p>Chọn một bộ phim và bắt đầu trải nghiệm điện ảnh của bạn.</p>
                    <a class="btn btn-primary" href="@Url.Action("Index")">Khám phá phim</a>
                </div>
            }
        </div>
    </div>
</section>
