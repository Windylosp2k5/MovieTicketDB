@model MovieTicketDB.Models.Event
@{
    ViewBag.Title = Model.Title;
}
<section class="page-shell">
    <div class="container" style="max-width:900px">
        <article class="event-card" style="@("--card-accent:" + Model.Accent + ";min-height:520px")">
            <span class="event-label">@Model.Label</span>
            <div>
                <h1 class="page-title">@Model.Title</h1>
                <p style="font-size:18px;max-width:650px">@Model.Description</p>
                <p>Áp dụng tại toàn bộ hệ thống PHP Cinema. Không quy đổi thành tiền mặt và không áp dụng đồng thời với ưu đãi khác.</p>
                <a class="btn btn-primary" href="@Url.Action("Index")">Chọn phim ngay</a>
                <a class="btn btn-outline" href="@Url.Action("Event")">Tất cả ưu đãi</a>
            </div>
        </article>
    </div>
</section>
