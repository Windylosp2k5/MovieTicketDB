<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="PHP Cinema - Đặt vé xem phim trực tuyến nhanh chóng và tiện lợi." />
    <title>@ViewBag.Title - PHP Cinema</title>
    <link href="@Url.Content("~/Content/Site.css")" rel="stylesheet" />
</head>
<body>
    <header class="site-header">
        <div class="container nav">
            <a class="brand" href="@Url.Action("Index", "Movie")">
                <span class="brand-mark brand-mark-php"><span>PHP</span></span>
                <span>PHP CINEMA</span>
            </a>
            <nav class="nav-links" aria-label="Điều hướng chính">
                <a href="@Url.Action("Index", "Movie")">Phim</a>
                <a href="@Url.Action("Theaters", "Movie")">Rạp chiếu</a>
                <a href="@Url.Action("Event", "Movie")">Ưu đãi</a>
                <a href="@Url.Action("DetailTicket", "Movie")">Vé của tôi</a>
            </nav>
            <div class="nav-actions">
                @if (Session["UserID"] == null)
                {
                    <a class="btn btn-ghost" href="@Url.Action("Login", "Movie")">Đăng nhập</a>
                    <a class="btn btn-primary" href="@Url.Action("Register", "Movie")">Đăng ký</a>
                }
                else
                {
                    <span class="user-name">@Session["FullName"]</span>
                    if ((Session["Role"] as string) == "Admin")
                    {
                        <a class="btn btn-primary" href="@Url.Action("Index", "Admin")">Quản trị</a>
                    }
                    <a class="btn btn-outline" href="@Url.Action("DetailTicket", "Movie")">Vé của tôi</a>
                    <a class="btn btn-ghost" href="@Url.Action("Logout", "Movie")">Thoát</a>
                }
            </div>
        </div>
    </header>

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-grid">
                <div>
                    <a class="brand" href="@Url.Action("Index", "Movie")">
                        <span class="brand-mark brand-mark-php"><span>PHP</span></span>
                        <span>PHP CINEMA</span>
                    </a>
                    <p>Không gian điện ảnh hiện đại, nơi mỗi bộ phim trở thành một trải nghiệm đáng nhớ.</p>
                </div>
                <div>
                    <h4>Khám phá</h4>
                    <a href="@Url.Action("Index", "Movie")">Phim đang chiếu</a>
                    <a href="@Url.Action("Theaters", "Movie")">Hệ thống rạp</a>
                    <a href="@Url.Action("Event", "Movie")">Khuyến mãi</a>
                </div>
                <div>
                    <h4>Hỗ trợ</h4>
                    <a href="mailto:support@phpcinema.vn">support@phpcinema.vn</a>
                    <a href="tel:19001234">1900 1234</a>
                    <span>08:00 - 23:00 hàng ngày</span>
                </div>
            </div>
            <div class="footer-bottom">© @DateTime.Now.Year PHP Cinema. Website đặt vé xem phim.</div>
        </div>
    </footer>
    @RenderSection("scripts", required: false)
</body>
</html>
